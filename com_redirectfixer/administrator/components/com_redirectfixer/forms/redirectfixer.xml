<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="redirectfixer">
      <fields name="redirectfixer">     
        <field
            name="articles"
            type="subform"
            label="COM_REDIRECTFIXER_AFFECTED_ARTICLES"
            multiple="true"
            min="0"
            max="1000">
            <form>
                <field
                    name="id"
                    type="number"
                    label="COM_REDIRECTFIXER_ARTICLE_ID"
                    readonly="true"
                    filter="integer"
                    min="1"
                />
                <field
                    name="title"
                    type="text"
                    label="COM_REDIRECTFIXER_ARTICLE_TITLE"
                    required="true"
                    filter="string"
                />
                <field
                    name="old_url"
                    type="text"
                    label="COM_REDIRECTFIXER_OLD_URL"
                    required="true"
                    filter="raw" 
                />
                <field
                    name="new_url"
                    type="text"
                    label="COM_REDIRECTFIXER_NEW_URL"
                    required="true"
                    filter="raw" 
                />
            </form>
        </field>
      </fields>
    </fieldset>
</form>